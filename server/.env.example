# Server config example. Copy to `.env` and adjust for your deployment.

# ポート番号（省略時は 3001）
PORT=3001

# CORS で許可するオリジン（カンマ区切り）。
# 未指定の場合は localhost:5173 / 4173 などの dev オリジンのみ許可される。
# 本番では必ず明示すること。
# 例:
# ALLOWED_ORIGINS=https://your-github-username.github.io,https://your-domain.example
ALLOWED_ORIGINS=
